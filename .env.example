UNMEET_ENV=development
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/unmeet

ENABLED_SOURCES=hackernews,github
INGESTION_FAIL_FAST=true

HACKERNEWS_FEEDS=topstories,newstories,beststories
HACKERNEWS_LIMIT=500

GITHUB_TOKEN=
GITHUB_REPOSITORIES=microsoft/vscode,langchain-ai/langchain,pallets/flask
GITHUB_ISSUES_LIMIT=1000
GITHUB_ISSUES_STATE=all
GITHUB_ISSUES_SORT=updated

STACKEXCHANGE_SITE=stackoverflow

REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=unMeet/0.1

EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2